{
  "manifest_version": 3,
  "name": "FB Tools",
  "version": "1.1",
  "description": "Bộ công cụ quản lý Facebook Page: theo dõi followers, xóa bài viết, phân tích content",
  "permissions": ["tabs", "sidePanel", "storage", "webRequest"],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://graph.facebook.com/*",
    "https://adsmanager.facebook.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "FB Page Follower Checker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
